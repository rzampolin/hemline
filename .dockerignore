# build context hygiene — keep the image build fast and the layers clean
.git
.claude
**/node_modules
**/.next
dist
coverage
*.tsbuildinfo

# local data lives on the Fly volume, never in the image
data

# ML sidecar artifacts — the image builds its OWN linux venv + HF cache in
# the Dockerfile `ml` stage; the local macOS venv/caches must never leak in
ml/.venv
ml/.cache
ml/.hf

# secrets
.env
.env.*

# not needed to build or run
e2e
docs
playwright-report
.DS_Store
README.md
eslint.config.mjs
vitest.config.ts
