# ── Anthropic (optional — app runs in demo mode without it) ─────────────
ANTHROPIC_API_KEY=            # sk-ant-...
AI_DAILY_BUDGET_USD=5         # hard cap; exceeded → automatic mock mode
EXTRACTION_MODEL=claude-haiku-4-5-20251001
RERANK_MODEL=claude-haiku-4-5-20251001
COLOR_MODEL=claude-sonnet-4-6

# ── eBay Browse API (optional — connector serves fixtures without it) ──
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE=EBAY_US
EBAY_AFFILIATE_CAMPAIGN_ID=   # EPN campaign; blank → source_url used as-is

# ── App ─────────────────────────────────────────────────────────────────
DATABASE_PATH=./data/hemline.db
SESSION_SECRET=change-me-32-chars-minimum-random
CRAWLER_CONTACT=rzampolin15@gmail.com   # goes in bot User-Agent
INGEST_ENABLE_SHOPIFY=true    # set false to skip real network crawls in dev
INGEST_ENABLE_JSONLD=true     # JSON-LD/sitemap connector (Reformation etc.)
JSONLD_MAX_PAGES=500          # product-page cap per store per crawl

# ── Sold-detection verification (pure HTTP, no AI cost — all optional) ──
VERIFY_ENABLE=true            # false disables both verification cron jobs
VERIFY_CLICK_CRON=*/15 * * * *   # clickout-queue drain cadence
VERIFY_ROLLING_CRON=0 * * * *    # rolling oldest-verified sweep cadence
VERIFY_QUEUE_BATCH=25         # max clicked listings re-checked per drain
VERIFY_ROLLING_BATCH=50       # rolling sweep size per tick (~50 req/h budget)

# ── Deployment (Fly.io / Docker — see DEPLOY.md; all optional in dev) ──────
# Admin basic auth "user:pass" — REQUIRED in production (admin routes 401 without it)
ADMIN_BASIC_AUTH=
# Prod rate limit for AI-spending endpoints, requests/min/user (default 20;
# color-analysis 5 and find-similar 10 have tighter built-ins). Active only
# when NODE_ENV=production, or RATE_LIMIT_FORCE=1 to test locally.
RATE_LIMIT_AI_RPM=
# Set to "off" to run the container web-only (no in-container ingest cron)
INGEST_SCHEDULER=
